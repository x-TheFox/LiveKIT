{
  "name": "livekit-discord-bot",
  "version": "1.0.0",
  "description": "Discord voice bot with LiveKit agent AI pipeline",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "agent": "tsx src/agent.ts start",
    "agent:dev": "tsx src/agent.ts dev",
    "bot": "tsx src/bot.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "download-files": "tsx src/agent.ts download-files",
    "dev": "concurrently \"pnpm agent:dev\" \"pnpm bot\"",
    "build": "tsc",
    "start:agent": "node dist/agent.js start",
    "start:bot": "node dist/bot.js"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@livekit/agents": "^1.2.3",
    "@livekit/agents-plugin-cartesia": "^1.2.3",
    "@livekit/agents-plugin-deepgram": "^1.2.3",
    "@livekit/agents-plugin-livekit": "^1.2.3",
    "@livekit/agents-plugin-openai": "^1.2.3",
    "@livekit/agents-plugin-silero": "^1.2.3",
    "@livekit/rtc-node": "^0.13.24",
    "concurrently": "^9.1.2",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.2.0",
    "livekit-server-sdk": "^2.15.0",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "@ffmpeg-installer/darwin-arm64",
      "esbuild",
      "ffmpeg-static",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  }
}
